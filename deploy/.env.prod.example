# ─────────────────────────────────────────────────────────────────────────────
# OMS-omni production env. Copy to the repo root as `.env` (it is gitignored):
#     cp deploy/.env.prod.example .env
# then fill in the values below. Used by docker-compose.prod.yml.
# ─────────────────────────────────────────────────────────────────────────────

# Public URL where the app is reachable (no trailing slash). The frontend is
# served at PUBLIC_URL and the API at PUBLIC_URL/api.
#   • with a domain:   https://oms.example.com
#   • IP only (demo):  http://<VM_PUBLIC_IP>
#   • free hostname:   http://<VM_PUBLIC_IP>.nip.io
PUBLIC_URL=http://CHANGE_ME

# Postgres password (the rest of DATABASE_URL is assembled in the compose file).
#   generate: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME

# End-user login (email/password → JWT). Required because AUTH_REQUIRED=true.
#   generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=12h

# Encrypts channel tokens / webhook secrets at rest.
#   generate: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=CHANGE_ME

# ── Payments ─────────────────────────────────────────────────────────────────
# mock = no real charges. stripe = live adapter (test or live secret key).
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_PAYMENT_METHOD=pm_card_visa
STRIPE_DECLINE_PAYMENT_METHOD=pm_card_chargeDeclined

# ── Fulfilment (WMS/3PL) ─────────────────────────────────────────────────────
WMS_PROVIDER=mock
SHIPBOB_API_KEY=

# ── Optional integrations (leave blank to disable) ───────────────────────────
GEMINI_API_KEY=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=write_inventory,read_inventory,read_products,read_orders
SHOPIFY_API_VERSION=2026-04
