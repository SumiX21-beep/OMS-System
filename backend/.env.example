# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oms_omni?schema=public"

# Redis (BullMQ + ATP cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# API
PORT=3000

# Inventory / ATP
ATP_CACHE_TTL_SECONDS=30
# Include inbound (in-transit) stock within this many days in ATP
ATP_INBOUND_HORIZON_DAYS=7

# Reservations
RESERVATION_TTL_SECONDS=900
RESERVATION_SWEEP_INTERVAL_MS=60000

# Channel sync + reconciliation
SYNC_DRAIN_INTERVAL_MS=10000
RECONCILE_INTERVAL_MS=300000

# AI assistant (Anthropic). Leave key blank to disable the LLM endpoint
# (the deterministic /ai/forecast endpoint works without it).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Shopify integration (global app credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=write_inventory,read_inventory,read_products,read_orders
SHOPIFY_API_VERSION=2026-04
# Public base URL of this OMS (for the OAuth redirect_uri)
APP_BASE_URL=http://localhost:3000

# Auth: when false (dev), x-tenant-id header is trusted as ADMIN; when true, an
# API key (Authorization: Bearer / x-api-key) is required.
AUTH_REQUIRED=false

# Order validation pipeline
TAX_RATE=0.08
PROMO_PERCENT=0

# Secret encryption at rest (channel access tokens, webhook secrets).
# 32-byte key as hex or base64, or any passphrase (hashed to 32 bytes).
# Generate: openssl rand -base64 32
# When unset (dev), secrets are stored in PLAINTEXT — set this before prod.
SECRET_ENCRYPTION_KEY=
